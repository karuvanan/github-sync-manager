```gitignore
# ==================================================
# Environment files
# ==================================================
.env
.env.local
.env.*.local

# ==================================================
# Local config / secrets
# ==================================================
config.local.py
config_private.py
secrets.py
secret.py
credentials.json
token.json
*.pem
*.key
*.crt

# ==================================================
# Python cache
# ==================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ==================================================
# Python virtual environment
# ==================================================
.venv/
venv/
env/
ENV/

# ==================================================
# Python build / package
# ==================================================
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ==================================================
# PyInstaller
# ==================================================
*.spec

# ==================================================
# Logs / cache / temp
# ==================================================
logs/
log/
*.log
cache/
tmp/
temp/
.tmp/
.cache/

# ==================================================
# Database files - do not upload real database
# ==================================================
*.sqlite
*.sqlite3
*.db
app.sqlite
database/*.sqlite
database/*.sqlite3
database/*.db

# Keep database schema if exists
!database/schema.sql

# ==================================================
# Backup files
# ==================================================
backup/
backups/
*.bak
*.backup
*.zip
*.rar
*.7z

# ==================================================
# Node / Composer folders if project has them
# ==================================================
node_modules/
vendor/

# Keep package definition files if exists
!package.json
!composer.json
!requirements.txt

# ==================================================
# IDE / editor
# ==================================================
.vscode/
.idea/
*.swp
*.swo

# ==================================================
# OS files
# ==================================================
.DS_Store
Thumbs.db
desktop.ini

# ==================================================
# Real private data - never upload
# ==================================================
customer_data/
client_data/
financial_data/
private_data/
real_data/
confidential/
```
